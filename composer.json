{
  "name": "markovicdenis/phpstan-invade",
  "description": "PHPStan extension that exposes the invaded object's members on Spatie\\Invade\\Invader<T>.",
  "type": "phpstan-extension",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "phpstan/phpstan": "^2.1",
    "spatie/invade": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "MarkovicDenis\\PHPStanInvade\\": "src/"
    }
  },
  "extra": {
    "phpstan": {
      "includes": [
        "phpstan-invade.neon"
      ]
    }
  }
}